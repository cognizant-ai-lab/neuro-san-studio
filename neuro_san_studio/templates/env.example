# Copy this file to .env and fill in the values you need.
# `neuro-san-studio` auto-loads .env from the project root.

# --- LLM provider keys (set whichever you use) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=

# --- Server / client ports ---
# NEURO_SAN_SERVER_HOST=localhost
# NEURO_SAN_SERVER_HTTP_PORT=8080
# NSFLOW_HOST=localhost
# NSFLOW_PORT=4173

# --- Logging ---
# LOG_LEVEL=info
