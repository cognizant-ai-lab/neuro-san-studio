 <your name>,\n       "Inquiry": <the inquiry>,\n       "Mode": Fulfill,\n       "Response" <your response>\n   }\n            ', 'aaosa_call': ConfigTree({'description': 'Depending on the mode, returns a natural language string in response.', 'parameters': ConfigTree({'type': 'object', 'properties': ConfigTree({'inquiry': ConfigTree({'type': 'string', 'description': 'The inquiry'}), 'mode': ConfigTree({'type': 'string', 'description': "\n'Determine' to ask the agent if the inquiry belongs to it, in its entirety or in part.\n'Fulfill' to ask the agent to fulfill the inquiry, if it can.\n'Follow up' to ask the agent to respond to a follow up.\n                    "})}), 'required': ['inquiry', 'mode']})}), 'aaosa_command': ''})
