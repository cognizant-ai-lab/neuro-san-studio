# NeuroSan API Gateway Configuration
# Copy this file to .env and edit with your settings

# ============================================================
# API Gateway Configuration (Port 9000)
# ============================================================
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=9000
API_GATEWAY_LOG_LEVEL=INFO
REQUEST_TIMEOUT=300

# ============================================================
# NeuroSan Server Configuration (Port 8080)
# ============================================================
NEURO_SAN_HOST=localhost
NEURO_SAN_PORT=8080

# Server settings
NEURO_SAN_SERVER_HOST=0.0.0.0
NEURO_SAN_SERVER_HTTP_PORT=8080
LOG_LEVEL=INFO

# Performance & Scaling
AGENT_HTTP_SERVER_INSTANCES=2
AGENT_MAX_CONCURRENT_REQUESTS=100
AGENT_MCP_ENABLE=true

# ============================================================
# LLM Provider API Keys
# ============================================================
# NOTE: For production, do NOT commit these to version control!
# Instead, use Azure Key Vault or GitHub Secrets

# OpenAI / ChatGPT
OPENAI_API_KEY=

# Anthropic / Claude
ANTHROPIC_API_KEY=

# Microsoft Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# Google Gemini
GOOGLE_API_KEY=

# NVIDIA
NVIDIA_API_KEY=

# Amazon AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ============================================================
# Logging Configuration
# ============================================================
# See deploy/logging.hocon for detailed logging configuration
AGENT_SERVICE_LOG_LEVEL=DEBUG
AGENT_SERVICE_LOG_JSON=./deploy/logging.hocon

# ============================================================
# Agent Configuration
# ============================================================
AGENT_MANIFEST_FILE=./registries/manifest.hocon ./registries/manifest_multiuser_overlay.hocon
AGENT_TOOL_PATH=./coded_tools
AGENT_TOOLBOX_INFO_FILE=./toolbox/toolbox_info.hocon
PYTHONPATH=.

# Server naming
AGENT_SERVER_NAME="neuro-san-app"
AGENT_SERVER_NAME_FOR_LOGS="NeuroSan Agent Server"

# Request metadata for observability
AGENT_FORWARDED_REQUEST_METADATA="request_id user_id"

# ============================================================
# MCP Configuration
# ============================================================
MCP_SERVERS_INFO_FILE=mcp/mcp_info.hocon

# ============================================================
# Dynamic Configuration
# ============================================================
# Enable periodic updates to agent manifests
AGENT_MANIFEST_UPDATE_PERIOD_SECONDS=0

# Enable temporary networks for CodedTools
AGENT_NETWORK_DESIGNER_USE_RESERVATIONS=true
AGENT_NETWORK_DESIGNER_RESERVATIONS_LIFETIME_IN_SECONDS=259200
AGENT_TEMPORARY_NETWORK_UPDATE_PERIOD_SECONDS=5

# ============================================================
# Azure-Specific Configuration
# ============================================================
# External server URL (useful for load balancers)
AGENT_EXTERNAL_SERVER_URL=

# S3/Azure Storage for reservations storage
AGENT_EXTERNAL_RESERVATIONS_STORAGE=
AGENT_RESERVATIONS_S3_BUCKET=

# ============================================================
# Development Configuration
# ============================================================
# Only use these in development environments!
THINKING_FILE=./logs/agent_thinking.txt
THINKING_DIR=./logs/thinking_dir
DEFAULT_SLY_DATA=

# Set to 'false' in production for better performance
LOGBRIDGE_ENABLED=true
