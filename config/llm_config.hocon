{
    # This file is NOT an agent network HOCON.
    # It defines a set of key-value pairs for substitution, typically used in agent network HOCON files.
    # Each key can be referenced in agent configs using the ${key} syntax.
    # Do not define agents or tools directly here—this file only provides reusable values.

    # Define a deployment environment, the default for which will be for local development.
    deployment_environment = "default"

    # Use "default" or override with env var if set
    # Other values we expect from the env var include "cluster" or "byok" (see definitions below).
    deployment_environment = ${AGENT_LLM_CONFIG_DEPLOYMENT_ENVIRONMENT}

    # This llm_config is the baseline for the default developer config.
    # The idea here is that if any of API keys for the providers are available,
    # use them.  Providers whose libraries and/or API keys are not available are
    # culled from usage by the underlying neuro-san system. Unless of course no API keys
    # are available at all, in which case the system will generate an error.
    "default_llm_config": {

        # Set the `class` key to one of the values listed below, then specify the model
        # using the `model_name` key.
        #
        # The available model names for each provider can be found in the corresponding links.
        #
        # | LLM Provider     | `class` Value   | Links for model names |
        # |------------------|-----------------|-----------------------|
        # | Amazon Bedrock   | `bedrock`       | https://docs.aws.amazon.com/bedrock/latest/userguide/model-ids.html |
        # | Anthropic        | `anthropic`     | https://platform.claude.com/docs/en/about-claude/models/overview |
        # | Azure OpenAI     | `azure-openai`  | https://learn.microsoft.com/azure/ai-services/openai/concepts/models |
        # | Google Gemini    | `gemini`        | https://ai.google.dev/gemini-api/docs/models |
        # | NVIDIA           | `nvidia`        | https://build.nvidia.com/explore/discover |
        # | Ollama           | `ollama`        | https://ollama.com/library |
        # | OpenAI           | `openai`        | https://platform.openai.com/docs/models |
        #
        # Note:
        # - For Ollama, the model must be downloaded locally before use.
        # - Additional LLM parameters (e.g., `temperature`, `max_tokens`) can be configured below.
        # - Agent-level control (e.g., `max_steps`) can also be set here.
        # - It is possible to have a separate llm_config describing a different LLM with different parameters for each agent network hocon file
        #or even for each agent within a network.
        #
        #   For more details, see:
        #   - https://github.com/cognizant-ai-lab/neuro-san/blob/main/neuro_san/internals/run_context/langchain/llms/default_llm_info.hocon
        #   - https://github.com/cognizant-ai-lab/neuro-san/blob/main/docs/agent_hocon_reference.md#llm_config

        "fallbacks": [
            {
                # Try OpenAI first
                "class": "openai",
                "model_name": "gpt-5.2",
            },
            {
                # Fall back to Anthropic Claude if OpenAI is unavailable.
                "class": "anthropic",
                "model_name": "claude-sonnet",
            },
            {
                # Fall back to Google Gemini if both OpenAI and Anthropic are unavailable.
                "class": "gemini",
                "model_name": "gemini-3-flash",
            }
        ]
    }


    # Similar to the default developer config above, except that when we encounter rate limiting from
    # one of the providers, we will immediately use the next one in the list without retrying in an
    # attempt to get better response times.
    "cluster_llm_config": {
        "fallbacks": [
            {
                # Try OpenAI first
                "class": "openai",
                "model_name": "gpt-5.2",
                "max_retries": 0,
            },
            {
                # Fall back to Anthropic Claude if OpenAI is unavailable.
                "class": "anthropic",
                "model_name": "claude-sonnet",
                "max_retries": 0,
            },
            {
                # Fall back to Google Gemini if both OpenAI and Anthropic are unavailable.
                "class": "gemini",
                "model_name": "gemini-3-flash",
                "max_retries": 0,
            },
            # Try the same round-robin again, but this time with retries.
            {
                # Try OpenAI first
                "class": "openai",
                "model_name": "gpt-5.2",
                "max_retries": 1,
            },
            {
                # Fall back to Anthropic Claude if OpenAI is unavailable.
                "class": "anthropic",
                "model_name": "claude-sonnet",
                "max_retries": 1,
            },
            {
                # Fall back to Google Gemini if both OpenAI and Anthropic are unavailable.
                "class": "gemini",
                "model_name": "gemini-3-flash",
                "max_retries": 1,
        ]
    }

    # A Bring-Your-Own-Key (BYOK) config.
    # Similar to the default developer config above, except that any api keys must be provided by the
    # client in sly_data.
    "byok_llm_config": {
        "fallbacks": [
            {
                # Try OpenAI first
                "class": "openai",
                "model_name": "gpt-5.2",
                "openai_api_key": "sly_data",
            },
            {
                # Fall back to Anthropic Claude if OpenAI is unavailable.
                "class": "anthropic",
                "model_name": "claude-sonnet",
                "anthropic_api_key": "sly_data",
            },
            {
                # Fall back to Google Gemini if both OpenAI and Anthropic are unavailable.
                "class": "gemini",
                "model_name": "gemini-3-flash",
                "google_api_key": "sly_data",
            }
        ]
    }

    # Assign the llm_config that will be used throughout the system via a double-substitution.
    "llm_config" = ${${deployment_environment}}_llm_config}
}
