# This file defines everything necessary for a data-driven test.
# The schema specifications for this file are documented here:
# https://github.com/cognizant-ai-lab/neuro-san/blob/main/docs/test_case_hocon_reference.md

{
    "agent": "basic/music_nerd_pro",
    "success_ratio": "1/1",
    "connections": [
        "direct"
    ],
    "interactions": [
        {
            "text": "Which band wrote \"Yellow Submarine\"?",
            "timeout_in_seconds": 120,
            "response": {
                "structure": {
                    "type": "json",
                    "required_keys": [
                        "answer",
                        "running_cost"
                    ],
                    "value": {
                        "running_cost": {
                            "type": "number"
                        }
                    },
                    "keywords": {
                        "answer": [
                            "The Beatles"
                        ]
                    }
                }
            }
        },
        {
            "text": "Where are they from?",
            "timeout_in_seconds": 120,
            "response": {
                "structure": {
                    "type": "json",
                    "required_keys": [
                        "answer",
                        "running_cost"
                    ],
                    "value": {
                        "running_cost": {
                            "type": "number"
                        }
                    },
                    "keywords": {
                        "answer": [
                            "Liverpool",
                            "England"
                        ]
                    }
                }
            }
        }
    ]
}
