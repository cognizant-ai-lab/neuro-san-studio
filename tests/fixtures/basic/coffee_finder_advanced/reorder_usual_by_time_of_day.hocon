# This file defines everything necessary for a data-driven test.
# The schema specifications for this file are documented here:
# https://github.com/cognizant-ai-lab/neuro-san/blob/main/docs/test_case_hocon_reference.md

# The agent routes "the usual" by time of day, selecting the morning preference at 8 am and the evening preference at 7 pm.

{
    # Describes what agent to test against.
    "agent": "basic/coffee_finder_advanced",

    # success_ratio is useful for passing to the assessor to find out why
    # a test is intermittently failing. Sometimes it's the agent prompt, but
    # sometimes it's the test itself.
    # Note: This number was increased for network failure identification and should be reverted afterward to 1/1.
    "success_ratio": "1/1",

    # Interactions are a series of dictionaries with request elements paired with
    # descriptions of response checks.
    "interactions": [
        {
            "timeout_in_seconds": 180,

            # Step 1 of 2: morning -> latte from Bob's Coffee Shop -> order 101.

            # This is to enable streaming_chat contents to thinking file for debug.
            # "chat_filter": "MAXIMAL",

            # Using the sly_data to set a hard time.
            "sly_data": {
                "test_mode": true,
                "time": "8 am"
            },

            # This is what we send as input to streaming_chat()
            "text": """
Hey, it's Pixel Smith. Get me my usual please.
""",

            # The response block describes how we are going to test what comes back
            "response": {

                # Text block says how we are going to examine the text of the response.
                "text": {

                    # Gist says we are going to ask an LLM about how the response
                    # matches up to our description of acceptance criteria.
                    # Each component of the list needs to pass muster in order to pass.
                    "gist": [
"The response mentions order ID 101.",
"The response identifies the customer as Pixel Smith.",
"The response identifies the item as a latte.",
"The response identifies the shop as Bob's Coffee Shop."
                    ],
                    "not_gist": [
"The response says the order was placed at Henry's Fast Food.",
"The response says the order was placed at Joe's Gas Station.",
"The response says the order was placed at Jack's Liquor Store.",
"The response says the item ordered was black coffee."
                    ]
                }
            }
        },
        {
            "timeout_in_seconds": 180,

            # Step 2 of 2: evening -> black coffee from Henry's Fast Food
            # (morning's Bob's is closed at 7 pm, so the morning preference
            # cannot be served even as a fallback).

            # This is to enable streaming_chat contents to thinking file for debug.
            # "chat_filter": "MAXIMAL",

            # Using the sly_data to set a hard time.
            "sly_data": {
                "test_mode": true,
                "time": "7 pm"
            },

            # This is what we send as input to streaming_chat()
            "text": """
Hey, it's Pixel Smith. Get me my usual please.
""",

            # The response block describes how we are going to test what comes back
            "response": {

                # Text block says how we are going to examine the text of the response.
                "text": {

                    # Gist says we are going to ask an LLM about how the response
                    # matches up to our description of acceptance criteria.
                    # Each component of the list needs to pass muster in order to pass.
                    "gist": [
"The response mentions order ID 201.",
"The response identifies the customer as Pixel Smith.",
"The response identifies the item as black coffee.",
"The response identifies the shop as Henry's Fast Food."
                    ],
                    "not_gist": [
"The response says the order was placed at Bob's Coffee Shop.",
"The response says the order was placed at Joe's Gas Station.",
"The response says the order was placed at Jack's Liquor Store.",
"The response says the item ordered was a latte."
                    ]
                }
            }
        }
    ]
}
