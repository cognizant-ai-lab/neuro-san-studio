# This file defines everything necessary for a data-driven test.
# The schema specifications for this file are documented here:
# https://github.com/cognizant-ai-lab/neuro-san/blob/main/docs/test_case_hocon_reference.md

# The agent appends a new preference to the pixel_smith topic without placing an order.

{
    # Describes what agent to test against.
    "agent": "basic/coffee_finder_advanced",

    # success_ratio is useful for passing to the assessor to find out why
    # a test is intermittently failing. Sometimes it's the agent prompt, but
    # sometimes it's the test itself.
    # Note: This number was increased for network failure identification and should be reverted afterward to 1/1.
    "success_ratio": "1/1",

    # Interactions are a series of dictionaries with request elements paired with
    # descriptions of response checks.
    "interactions": [
        {
            "timeout_in_seconds": 180,

            # The new preference must be appended to the existing pixel_smith
            # topic; no order should be placed in this turn.

            # This is to enable streaming_chat contents to thinking file for debug.
            # "chat_filter": "MAXIMAL",

            # Using the sly_data to set a hard time.
            "sly_data": {
                "test_mode": true,
                "time": "8 am"
            },

            # This is what we send as input to streaming_chat()
            "text": """
Hey, it's Pixel Smith. I'm switching to latte from Bob's Coffee Shop from now on. Please remember that.
""",

            # The response block describes how we are going to test what comes back
            "response": {

                # Text block says how we are going to examine the text of the response.
                "text": {

                    # Gist says we are going to ask an LLM about how the response
                    # matches up to our description of acceptance criteria.
                    # Each component of the list needs to pass muster in order to pass.
                    "gist": [
"The response acknowledges Pixel Smith's preference has been recorded, updated, or remembered.",
"The response mentions latte.",
"The response mentions Bob's Coffee Shop."
                    ],
                    "not_gist": [
"The response includes an order ID, confirming an order was placed."
                    ]
                }
            }
        }
    ]
}
