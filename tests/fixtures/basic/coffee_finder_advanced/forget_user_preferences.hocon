# This file defines everything necessary for a data-driven test.
# The schema specifications for this file are documented here:
# https://github.com/cognizant-ai-lab/neuro-san/blob/main/docs/test_case_hocon_reference.md

# The agent deletes the pixel_smith topic when asked, and a follow-up turn confirms nothing remains in memory.

{
    # Describes what agent to test against.
    "agent": "basic/coffee_finder_advanced",

    # Minimum pass ratio for intermittent-failure triage.
    "success_ratio": "1/1",

    # Interactions are a series of dictionaries with request elements paired with
    # descriptions of response checks.
    "interactions": [
        {
            "timeout_in_seconds": 120,

            # Step 1 of 2: ask the agent to forget the user; the pixel_smith
            # topic should be deleted from persistent memory immediately.

            # This is to enable streaming_chat contents to thinking file for debug.
            # "chat_filter": "MAXIMAL",

            # Using the sly_data to set a hard time.
            "sly_data": {
                "test_mode": true,
                "time": "8 am"
            },

            # This is what we send as input to streaming_chat()
            "text": """
Hey, it's Pixel Smith. Please forget everything you know about me.
""",

            # The response block describes how we are going to test what comes back
            "response": {

                # Text block says how we are going to examine the text of the response.
                "text": {

                    # Gist says we are going to ask an LLM about how the response
                    # matches up to our description of acceptance criteria.
                    # Each component of the list needs to pass muster in order to pass.
                    "gist": [
"The response acknowledges the forget request, confirming the user's data has been or is being deleted."
                    ],
                    "not_gist": [
"The response declines to delete on the grounds that no data was stored for the user (e.g., 'nothing to delete', 'no stored information found').",
"The response refuses the request, defers it, or asks the user to confirm before deleting."
                    ]
                }
            }
        },
        {
            "timeout_in_seconds": 120,

            # Step 2 of 2: re-ask what the agent remembers; with the topic
            # deleted, the agent must report nothing stored about the user.

            # This is to enable streaming_chat contents to thinking file for debug.
            # "chat_filter": "MAXIMAL",

            # Using the sly_data to set a hard time.
            "sly_data": {
                "test_mode": true,
                "time": "8 am"
            },

            # This is what we send as input to streaming_chat()
            "text": """
It's Pixel Smith again. What do you remember about me?
""",

            # The response block describes how we are going to test what comes back
            "response": {

                # Text block says how we are going to examine the text of the response.
                "text": {

                    # Gist says we are going to ask an LLM about how the response
                    # matches up to our description of acceptance criteria.
                    # Each component of the list needs to pass muster in order to pass.
                    "gist": [
"The response indicates the agent has no stored info about the user. Follow-up offers of help are fine."
                    ],
                    "not_gist": [
"The response mentions black coffee.",
"The response mentions Joe's Gas Station.",
"The response lists any stored preference, drink, or shop for the user."
                    ]
                }
            }
        }
    ]
}
