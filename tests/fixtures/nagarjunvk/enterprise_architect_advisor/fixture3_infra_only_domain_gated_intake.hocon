# Fixture 3 — Infrastructure-only migration, domain-gated intake template
#
# The user describes a pure infrastructure lift: VMware VMs → Azure, no application
# modernisation, no database signal, no integration signal.
#
# Expected behaviour in Phase 1 (domain-gated rules):
#   - The intake template MUST NOT ask about frontend/backend technology
#     (no application-layer signal → application_architect domain-gate fails)
#   - The intake template MUST NOT ask about database engine
#     (no database signal → data_architect domain-gate fails)
#   - The intake template MUST NOT ask about messaging / integration technology
#     (no integration signal → integration_architect domain-gate fails)
#   - The intake template MUST ask about DR / downtime / cutover (operations_architect,
#     always plausible when VM migration is in scope)
#   - The intake template MUST ask about licensing agreements for Hybrid Benefit
#     (finops_architect, always plausible when VM migration is in scope)
#   - The intake template MUST NOT re-ask about target cloud (Azure confirmed)
#   - The intake template MUST NOT re-ask about timeline (12 months confirmed)
{
    "agent": "nagarjunvk/enterprise_architect_advisor",
    "connections": ["direct"],
    "timeout_in_seconds": 600,
    "success_ratio": "1/1",

    "interactions": [
        {
            # Pure infra lift — VMware to Azure, 200 VMs, 12-month timeline, no app signals
            "text": "We need to migrate our VMware environment to Azure. We have approximately 200 VMs running Windows Server workloads. This is a pure lift-and-shift — we are not modernising applications at this stage. Our target is Azure and we want to complete the migration within 12 months.",

            "response": {
                "text": {
                    # Core gate check: domain-gated intake template produced
                    "gist": "The response is a Phase 1 intake template that asks the user clarifying questions. It does not immediately launch into a full specialist analysis with scored option tables.",

                    # Should not appear since no app/data/integration signals
                    "not_keywords": [
                        "Current frontend technology",
                        "backend technology",
                        "programming language",
                        "database engine",
                        "messaging technology",
                        "Score /100"
                    ]
                }
            }
        }
    ]
}
