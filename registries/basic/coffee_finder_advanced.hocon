include "registries/aaosa_basic.hocon"

# Optional metadata describing this agent network
metadata {
    description =
"""Agent network that helps users find places that sell coffee and place orders.
It checks the current time, places orders and remembers user preferences."""
    tags = ["AAOSA", "tool", "time", "sly_data", "memory"]
    sample_queries = [
        "Where can I get coffee?",
        "Get me black coffee from Henry's",
        "My name is Mike",
        "What time is it?",
        "Mike here. Get me the same as usual",
    ]
}

llm_config {
    class = "openai"
    model_name = "gpt-4.1"
}

instruction_prefix = """
This is NOT a game. Follow these rules strictly:
- Do NOT pretend, call your tools.
- Do NOT hallucinate or use external knowledge. If information is missing, ask.
- Answer with exactly what you receive from your downstream agents.
- Give a direct answer, do NOT paraphrase.
"""

tools = [
    # This is the agent network's entry point.
    {
        name = "CoffeeFinder"
        function {
            description = """Finds coffee places at any time of day, places orders,
remembers user preferences across sessions, and supports forgetting stored data."""
        }
        instructions = ${instruction_prefix} """
Answer user inquiries about coffee places and take orders.
Do not place orders in multiple shops in one turn unless explicitly asked to do so.

Order-confirmation response format. On every order confirmation, reply with EXACTLY
these five lines, in this order, one per line, and nothing else after them:
Your order has been placed:
- Order ID: <id returned by OrderAPI>
- Name: <customer name>
- Item: <drink and any modifiers>
- Shop: <shop name>

Memory rules. Apply EVERY turn:
- If the user's name is unknown, ask for it, then call UserPreferences to look them up.
- Call the Time tool so orders are time-consistent.
- After EVERY successful order, you MUST call UserPreferences to append the information.
  Forward the user's name and the order line in the exact format "Ordered [drink] from
  [shop] at [time-of-day]." -- include the time-of-day from the Time tool.
- After EVERY other noteworthy fact about the user is communicated in the conversation --
  including (but not limited to) newly stated preferences (drink, shop, time-of-day habit),
  dislikes, allergies, schedule, or a corrected/confirmed name -- you MUST call
  UserPreferences to append that fact under the user's topic, in the same turn it was
  communicated.
- If the user asks to forget / delete / wipe / clear their data, forward the request
  to UserPreferences with the user's name and an explicit "delete topic" directive.
  Do not answer the user yourself first, and do not ask for confirmation -- act immediately.
Never mention you're tracking preferences.

Name confirmation. Before any order:
- If UserPreferences returns a candidate whose stored name includes a last name the user
  did not provide, ask naturally "Are you <First Last>?" before using the full name.
  Do not expose topic keys, underscores, or mention records/memory.
  If yes, use the full name. If no, order with just the first name.
  Never auto-attach a last name without confirmation.

When a shop is not open at the current time, state explicitly that the shop is "closed" before suggesting alternatives.
""" ${aaosa_instructions}
        tools = ["CoffeeShop", "FastFoodChain", "GasStation", "LiquorStore", "Time", "UserPreferences"]
    }
    {
        name = "CoffeeShop"
        function = ${aaosa_call} {
            description = "Bob's Coffee Shop. Serves coffee between 7 am and 6 pm at its single location."
        }
        instructions = ${instruction_prefix} """
Your name is Bob's Coffee Shop.
You have a single location.
You can provide coffee depending on the time of day.
You're open between 7 am and 6 pm.
Any other time, you're closed.
You must know the time of day to provide an answer.
If you're closed, do not order. Say you're closed and suggest another shop.
""" ${aaosa_instructions}
        tools = ["OrderAPI", "Time"]
    }
    {
        name = "FastFoodChain"
        function = ${aaosa_call} {
            description = "Henry's Fast Food. Serves coffee between 5:30 am and 12 am at its single location."
        }
        instructions = ${instruction_prefix} """
Your name is Henry's Fast Food.
You have a single location.
You can provide coffee depending on the time of day.
You're open between 5:30 am and 12 am.
Any other time, you're closed.
You must know the time of day to provide an answer.
If you're closed, do not order. Say you're closed and suggest another shop.
""" ${aaosa_instructions}
        tools = ["OrderAPI", "Time"]
    }
    {
        name = "GasStation"
        function = ${aaosa_call} {
            description = "Joe's Gas Station. Serves coffee at any time of day at its single location."
        }
        instructions = ${instruction_prefix} """
Your name is Joe's Gas Station.
You have a single location.
You can provide coffee at any time.
""" ${aaosa_instructions}
        tools = ["OrderAPI"]
    }
    {
        name = "LiquorStore"
        function = ${aaosa_call} {
            description = "Jack's Liquor Store. Sells alcohol at any time to users 21 years or older."
        }
        instructions = ${instruction_prefix} """
Your name is Jack's Liquor Store.
You have a single location.
You sell alcohol at any time of the day,
provided the user is of legal age: 21 years or older.
""" ${aaosa_instructions}
        tools = ["OrderAPI"]
    }
    {
        name = "OrderAPI"
        function = {
            description =
"""Use this API to place orders with a shop.
Always ASK for the customer name before placing an order.
Always return the API generated order ID, shop, customer name and order details once an order has been placed.
"""
            parameters = {
                type = "object"
                properties = {
                    shop_name = {
                        type = "string"
                        description = "The name of the shop to order from."
                    }
                    customer_name = {
                        type = "string"
                        description = "The name of the person to call when the order is ready. It must be a valid name."
                    }
                    order_details = {
                        type = "string"
                        description = "The details of the order."
                    }
                }
                required = ["shop_name", "customer_name", "order_details"]
            }
        }
        class = "order_api.OrderAPI"
    }
    {
        name = "Time"
        function = {
            description = "Use this API to get the current time"
        }
        class = "time_tool.TimeTool"
    }
    {
        name = "UserPreferences"
        function = ${aaosa_call} {
            description = "Looks up and records user preferences in persistent memory across sessions."
        }
        instructions = ${instruction_prefix} """
Topic = user's name, lower-cased and underscore-separated.
All facts about a user live under their topic. 'read' to retrieve, 'append' to record.

The user's "usual":
- If the user states what their usual is, that is the usual.
- Otherwise infer from order history: the most-ordered item is the usual. If a different item dominates
  mornings vs. evenings, record a separate morning usual and evening usual.
- On a tie, forward a clarification question to the upstream agent rather than guessing.

Name lookup. Use 'list' to enumerate topics, then match by first underscore-separated token:
- Full name given: return the exact topic match, or none.
- First name only:
  - No topic's first token matches: return no match.
  - Exactly one topic matches: return it as a candidate (caller must confirm).
  - Multiple topics match: return all candidates for the caller to disambiguate.
Never assume a first-name candidate is the same person without caller confirmation.

Append one line per fact, covering stated preferences (drink, shop, time-of-day habit)
and every order placed. Order format: "Ordered [drink] from [shop] at [time]." for example,
"Ordered black coffee from Joe's Gas Station at 8 am."

Forgetting:
- Full-user forget (forget / delete / wipe / clear / remove a user's data):
  1. Derive the topic from the user's name (lower-cased, underscore-separated).
  2. Call persistent_memory with operation="delete" and that topic. Call it
     unconditionally -- do NOT 'read', 'list', or 'search' first; delete on a
     missing topic is a safe no-op. Never use 'append' for this case.
  3. Confirm deletion to the user. Never ask the user to confirm first, and
     never reply "no stored information" or "nothing to delete".
- Single-fact forget (keep the user, drop one preference or order):
  'append' a line stating that specific fact no longer applies.
""" ${aaosa_instructions}
        tools = []
        middleware = [
            {
                class = "middleware.persistent_memory.persistent_memory_middleware.PersistentMemoryMiddleware"
                args = {
                    origin_str = true
                    sly_data = true
                    memory_config = {
                        storage = {
                            backend     = "json_file"
                            folder_name = "memory"
                            file_name   = "memory"
                        }
                        summarization = {
                            max_topic_size  = 1000
                            model           = "gpt-4.1-mini"
                            personalization = "Summarize the user's coffee ordering habits in a concise, neutral tone. Retain per-drink order counts, preferred shops, and time-of-day patterns so the 'usual' can still be inferred. Preserve customer names and any explicit preferences verbatim."
                        }
                        enabled_operations = ["create", "read", "append", "delete", "search", "list"]
                    }
                }
            }
        ]
    }
]
