# agent_harness_designer
#
# An agent network that designs other agent networks with configurable middleware and skills.
# Extends agent_network_designer by allowing each agent to be equipped with specific
# capabilities, tools, and processing layers tailored to its role.
#
# Each agent in the network can be assigned:
#   - Middleware: processing layers that intercept, transform, or augment the agent's
#     inputs and outputs (e.g. logging, rate limiting, memory, context injection)
#   - Skills: discrete capabilities or tools the agent can invoke to fulfill its purpose
#
# Future Implementation — Plugins:
#   A natural extension of this design would be a plugin system, where a plugin is a
#   pre-bundled package of middleware and tools curated for a specific agent role.
#   For example, a "researcher" plugin might bundle a web search tool, a summarization
#   middleware, and a citation tracker — while a "coder" plugin might include a code
#   execution tool, a linting middleware, and a memory layer for tracking past outputs.
#   Plugins would allow harnesses to be composed quickly from role-matched presets,
#   reducing manual configuration and encouraging reuse across different agent networks.
#
# Implementation note:
#   This file is a thin top-level wrapper that includes the shared base
#   (registries/agent_network_designer_base.hocon) and overrides only the
#   fields that differ from agent_network_designer — currently:
#     - instructions:  adds step 1.5 (middleware_manager)
#     - tools:         adds /middleware_manager
#     - allow.from_downstream.sly_data:  adds middleware_info
#     - allow.from_downstream.messages:  adds /middleware_manager
#   Everything else — function schema, middleware, allow.to_upstream, etc. —
#   is inherited automatically. Edit the base file to change shared behavior.

{
    include "registries/agent_network_designer_base.hocon"

    # Middleware-specific workflow step inserted between step 1 and step 2
    # of the shared instructions. The before/after pieces come from the base.
    "_instructions_middleware_step": """1.5) Add or remove middleware (must be called at least once after step 1)
- Always call `middleware_manager` at least once after the network structure is created or modified.
- `middleware_manager` **MUST** be called in parallel with any steps after step 1.
- You may call `middleware_manager` multiple times as you iterate on the network.

"""

    # Override only the middleware-aware fields of the front-man agent.
    # The substitution ${_designer_agent} in the base's `tools` array
    # picks up these merged values at resolution time.
    "_designer_agent": {
        "instructions": ${_instructions_before_middleware_step}${_instructions_middleware_step}${_instructions_after_middleware_step}

        "allow": {
            "from_downstream": {
                # Extend the inherited lists rather than replace, so any
                # additions made to the base also flow through.
                "sly_data": ${_designer_agent.allow.from_downstream.sly_data} ["middleware_info"]
                "messages": ${_designer_agent.allow.from_downstream.messages} ["/middleware_manager"]
            }
        }

        "tools": ${_designer_agent.tools} ["/middleware_manager"]
    }
}
