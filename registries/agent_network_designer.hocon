# Modular external-agent design:
# After step 1 (always agent_network_editor), the designer may call any number of follow-up
# external agents in parallel. Two of them — agent_network_instructions_editor and
# agent_network_query_generator — are core and always-on. Additional toggleable modules live
# in middleware/agent_network_designer/external_agents.hocon and are enabled per-env-var.
# ExternalAgentsMiddleware reads that catalog and appends each enabled module's workflow-step
# text to this agent's system prompt. To add a new toggleable external agent: register a new
# entry in the catalog, append its tool ref + its message-allow entry below, and add any new
# sly_data keys it returns to allow.from_downstream.sly_data.
{
    "metadata": {
        "description": "Multi-agent system designed to create or modify other multi-agent systems. Provide an organization name or use case description, and it will design a new multi-agent system, save it to registries in HOCON format, add it to manifest.hocon, and generate example usage queries. The system orchestrates network structure design, instruction refinement, query generation, and validation.",
        "tags": ["experimental", "tool"],
        "sample_queries": [
            "Create a network for UNHCR back-office",
            "Design an agent network for a hospital management system",
            "Build a multi-agent system for e-commerce customer support",
            "Design an agent network for employee onboarding"
        ]
    },

    # Load the shared LLM configuration from a single source of truth.
    # This allows users to change the model in one file rather than
    # modifying the configuration for each agent network.
    # Note that the file path here is relative to the root level of the repo.
    include "config/llm_config.hocon",
    "max_steps": 40000,
    "max_execution_seconds": 6000,
    "error_formatter": "json",
    "error_fragments": ["Error:", "Exception:", "Traceback (most recent call last)"],
    "tools": [
        # This first agent definition is regarded as the "Front Man", which
        # does all the talking to the outside world/client.
        #
        # Some disqualifications from being a front man:
        #   1) Cannot use a CodedTool "class" definition
        #   2) Cannot use a Tool "toolbox" definition
        #
        # Besides the first agent being the front man, these tool definitions
        # do not have to be in any particular order. How they are linked and
        # call each other is defined within their own specs.
        # This could be a graph, potentially even with cycles.
        {
            "name": "agent_network_designer",
            "function": {
                "description": "Create or modify an agent network.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "agent_network_description": {
                            "type": "string",
                            "description": "For `create`: A full description of the project, business, or company this agent network represents. For `modify`: A clear description of the change you want to make to the existing agent network."
                        },
                        "mode": {
                            "type": "string",
                            "description": "Indicates whether to build a brand new agent network (`create`) or to edit the existing one (`modify`)."
                        }
                    },
                    "required": ["agent_network_description", "mode"]
                },

                # You can optionally specify the schema needed for any sly_data as input.
                # This is to allow generic clients to know what to expect for private-data inputs
                # that do not belong in the chat stream.
                "sly_data_schema": {
                    "type": "object",
                    "properties": {
                        "agent_network_definition": {
                            "type": "object",
                            "description": "An internal representation of the agent network used for further iteration."
                        },
                        "agent_network_hocon_file": {
                            "type": "string",
                            "description": """
The path of an agent network config file. HOCON (.hocon) is preferred — hence the field name — but JSON (.json) is also accepted. Accepted in order:
(1) an absolute path; (2) a path relative to the current working directory (typically the repo root, e.g. 'registries/generated/foo.hocon');
(3) a path relative to the registries folder — the directory of the first file in the AGENT_MANIFEST_FILE env var, falling back to 'registries' in the repo root.
This is for users who want to provide the full agent network definition as input.
"""
                        },
                        "agent_network_name": {
                            "type": "string",
                            "description": "The name of the agent network that was created or modified."
                        },
                        "agent_reservations": {
                            "type": "array",
                            "description": """
A list of reservation structures describing the temporary agent networks that were created by interacting
with this agent. By convention, the last one in the list is a top-level handle which may reference any others listed.
""",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "reservation_id": {
                                        "type": "string",
                                        "description": """
The unique identifier of the reserved temporary agent network.
This can be used to invoke the newly created network later on the same server/cluster.
"""
                                    }
                                }
                            }
                        },
                        "skip_designer": {
                            "type": "boolean",
                            "description": "Use this key when you want to persist the agent network definition without having the LLM make any modifications."
                        }
                    }
                    # Note: Neither of these fields are strictly required in order to kick off creating a new network.
                },

                # You can also optionally specify the schema needed for any sly_data output.
                # This is to allow generic clients to know what to expect for private-data outputs
                # that do not belong in the chat stream.
                "sly_data_output_schema": {
                    "type": "object",
                    "properties": {
                        "agent_network_definition": {
                            "type": "object",
                            "description": "An internal representation of the agent network used for further iteration."
                        },
                        "agent_network_hocon_text": {
                            "type": "string",
                            "description": "The contents of an agent network HOCON file describing the created network"
                        },
                        "agent_network_name": {
                            "type": "string",
                            "description": "The name of the agent network that was created or modified."
                        },
                        "agent_reservations": {
                            "type": "array",
                            "description": """
A list of reservation structures describing the temporary agent networks that were created by interacting
with this agent. By convention, the last one in the list is a top-level handle which may reference any others listed.
""",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "reservation_id": {
                                        "type": "string",
                                        "description": """
The unique identifier of the reserved temporary agent network.
This can be used to invoke the newly created network later on the same server/cluster.
"""
                                    },
                                    "lifetime_in_seconds": {
                                        "type": "float",
                                        "description": """
Approximate lifetime (in seconds) of the temporary agent network reservation suitable for reporting to end users.
"""
                                    },
                                    "expiration_time_in_seconds": {
                                        "type": "float",
                                        "description": """
The number of seconds since the epoch (Jan 1, 1970) when the reservation will expire.
After this time the network can no longer be counted upon to exist.
"""
                                    }
                                }
                            }
                        }
                    },
                    # Note: "agent_reservations" is not strictly required depending on env vars.
                    "required": ["agent_network_definition", "agent_network_hocon_text", "agent_network_name"]
                }
            },
            "instructions": """
You are responsible for designing and modifying agent networks based on user requirements.
Only answer inquiries that are directly within your area of expertise. Do not try to help for other matters. Do not mention what you can NOT do. Only mention what you can do.

Take the following steps. Make sure you don't miss any details and follow the steps carefully.

LOOPABLE WORKFLOW:
You may repeat the cycle any number of times until the network is ready for finalization.

Step 1) Create or modify the network structure (sequential, always first)
- If the user provides a company name or domain description for a new network, generate an agent network definition that mirrors relevant workflows and responsible nodes. Call your `agent_network_editor` tool. Ensure the agent network name is snake case.
- If the user asks to modify an existing network's structure (add/remove agents, or change up-chains/down-chains), call `agent_network_editor` with the modification instructions.
- You may call `web_search` to find more details on the company or domain.
- If the user only asks to modify agent instructions (no structural changes), skip the structural edit and proceed to step 2.
- Wait for and inspect the response from `agent_network_editor` before proceeding.

Step 2) After step 1 returns, call the following follow-up external agents IN PARALLEL as appropriate (issue them in a single response when more than one applies):

- `agent_network_instructions_editor`: Write or refine agents' `instructions` and `description` fields. Call after any structural change or when the user asks to modify instructions only. You may call it multiple times as you iterate.
- `agent_network_query_generator`: Generate 3–4 sample queries for the current network. Call after any change so the queries stay in sync with the structure. You may call it repeatedly until the queries accurately reflect the network behavior.

Step 3) AFTER every step 2 follow-up has returned, call any additional toggleable external agents SEQUENTIALLY (one tool per response). Step 3 tools are listed below this workflow when they are enabled — do not invoke them earlier or in parallel with step 2, because they write to the same `agent_network_definition` that `agent_network_instructions_editor` writes to and a parallel `to_upstream` merge would clobber their changes.

Operational notes:
- Step 1 must complete before step 2 is issued. Step 2's parallel follow-ups must all return before step 3 is issued.
- Within step 2, issue every follow-up in a single response so they run concurrently. Wait for every response before iterating.
- Within step 3, issue one tool per response and wait for its result before issuing the next.
- You may call `web_search` at any point to gather domain context.
- Iteratively refine the structure, instructions, queries, and any step 3 additions.
""",
            "allow": {
                "to_upstream": {
                    "sly_data": [
                        "agent_network_definition",
                        "agent_network_hocon_text",
                        "agent_network_name",
                        "agent_reservations"
                    ]
                },
                "from_downstream": {
                    # `middleware_info` is always allowed so it can flow back when the
                    # /middleware_manager external agent is enabled; harmless otherwise.
                    "sly_data": ["agent_network_definition", "agent_network_name", "agent_network_queries", "mcp_servers", "subnetworks", "toolbox_info", "middleware_info"],
                    # Allow all messages sent from specific downstream agents to be reported
                    # as if they came back from this agent network. `/middleware_manager` is
                    # always listed; it just isn't called when its env var is off.
                    "messages": ["/agent_network_editor", "/agent_network_query_generator", "/agent_network_instructions_editor", "/middleware_manager"]
                },
                "to_downstream": {
                    # Optionally propagate any BYOK keys to downstream tools.
                    "sly_data": ["agent_network_definition", "agent_network_name", "agent_network_queries",
                                 ${?llm_config_key}]
                },
                "to_tracing": {
                    # These keys are not considered private and OK to send to an Observability backend
                    "sly_data": [
                        "agent_network_definition",
                        "agent_network_hocon_text",
                        "agent_network_name",
                        "agent_reservations"
                    ]
                }
            },
            # Every external agent the designer can talk to is statically declared here.
            # Toggleable modules (currently /middleware_manager) are always wired in; whether
            # the LLM is told about them is decided at runtime by ExternalAgentsMiddleware.
            "tools": ["/agent_network_editor", "/agent_network_query_generator", "/agent_network_instructions_editor", "/middleware_manager", "web_search"],
            # Parse any JSON in responses into the structure field of the ChatMessage.
            "structure_formats": "json",
            "middleware": [
                {
                    "class": "middleware.agent_network_designer.agent_network_definition_middleware.AgentNetworkDefinitionMiddleware",
                    "args": {
                        "progress_reporter": true,
                        "sly_data": true
                    }
                },
                {
                    # Appends instructions for every enabled toggleable external-agent module
                    # to the system prompt at runtime. Catalog lives at
                    # middleware/agent_network_designer/external_agents.hocon.
                    "class": "middleware.agent_network_designer.external_agents_middleware.ExternalAgentsMiddleware",
                    "args": {
                        "sly_data": true
                    }
                },
                {
                    "class": "middleware.agent_network_designer.persistence.agent_network_persistence_middleware.AgentNetworkPersistenceMiddleware",
                    "allow": {
                        "reservations": true
                    },
                    "args": {
                        "reservationist": true,
                        "sly_data": true,
                    }
                }
            ]
        },

        {
            "name": "web_search",
            "toolbox": "ddgs_search"
        },

    ]
}
