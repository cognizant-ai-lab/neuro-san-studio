# Environment Configuration for ${project_name}
#
# Copy this file to .env and fill in your API keys.
# Never commit your .env file to version control!

# LLM Provider API Keys
# Uncomment and fill in the keys for your chosen provider(s)

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY="your-openai-api-key"

# Anthropic - https://console.anthropic.com/
# ANTHROPIC_API_KEY="your-anthropic-api-key"

# Google Gemini - https://ai.google.dev/gemini-api/docs/api-key
# GOOGLE_API_KEY="your-google-api-key"

# AWS Bedrock - https://aws.amazon.com/bedrock/
# AWS_ACCESS_KEY_ID="your-aws-access-key"
# AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
# AWS_DEFAULT_REGION="us-east-1"

# Azure OpenAI - https://azure.microsoft.com/en-us/products/ai-services/openai-service/
# AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com/"
# AZURE_OPENAI_API_KEY="your-azure-openai-key"
# OPENAI_API_VERSION="2024-12-01-preview"
# AZURE_OPENAI_DEPLOYMENT_NAME="your-deployment-name"

# Ollama (local) - https://ollama.ai/
# No API key needed for local Ollama

# neuro-san Configuration
# Path to your manifest file (relative to project root)
AGENT_MANIFEST_FILE="registries/manifest.hocon"

# Path to your coded tools directory
AGENT_TOOL_PATH="coded_tools"

# Server ports (optional, defaults shown)
# AGENT_HTTP_PORT=8080
# AGENT_GRPC_PORT=30011
