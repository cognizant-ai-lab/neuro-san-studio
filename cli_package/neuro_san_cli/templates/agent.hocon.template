# Agent: ${agent_name}
#
# Documentation: https://github.com/cognizant-ai-lab/neuro-san/blob/main/docs/agent_hocon_reference.md

{
    # Include shared LLM configuration
    include "registries/llm_config.hocon"

    "metadata": {
        "description": "${description}"
        "tags": []
        "sample_queries": [
            "Add example queries here"
        ]
    }

    "tools": [
        # Front Man - the entry point for user interactions
        {
            "name": "${agent_name}"

            "function": {
                "description": """
${description}

How can I help you today?
"""
            }

            "instructions": """
You are ${agent_name}, an AI assistant.

Your responsibilities:
1. Understand the user's request
2. Delegate to appropriate helper agents/tools
3. Synthesize results and provide a clear response

Be helpful, accurate, and concise.
"""
            # Add helper agents/tools here:
            # "tools": ["helper_agent", "another_tool"]
        }

