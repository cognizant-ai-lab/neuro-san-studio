# Localhost and local development URLs
http://localhost
http://127.0.0.1

# Private network addresses
http://192.168.

# Placeholder and example URLs
https://github.com/your-username/
https://mydomain.my.salesforce.com/
https://your-instance.service-now.com/
https://test.service-now.com/
https://your-resource.openai.azure.com/
https://your-domain.atlassian.net
http://otherdomain.com/
file:///path/to/
http://arxiv.org/abs/$

# Sites with network-level blocks (not resolvable via --accept)
https://www.united.com/
https://mcp/

# URLs whose base path is not browsable (returns 400 or 404)
# raw.githubusercontent.com requires a file path; the middleware appends SKILL.md at runtime, but 400 cannot be globally accepted without masking broken links
https://raw.githubusercontent.com/anthropics/skills/main/skills/internal-comms/
https://api.anthropic.com/
https://api.smith.langchain.com/
https://api.salesforce.com

# Jinja2 template URLs (lychee cannot resolve these at scan time)
file://.*%7B%7B.*%7D%7D

# Shell/template variable URLs (lychee cannot resolve these)
https://go.dev/dl/go\$
